# Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://your-app.herokuapp.com/auth/callback

# Google token for Heroku (run setup-google locally, then paste the token JSON here)
# GOOGLE_TOKEN_JSON={"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":...}

PORT=3001
